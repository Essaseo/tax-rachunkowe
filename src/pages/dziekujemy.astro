---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---
<BaseLayout
  title="Dziękujemy za kontakt | TAX Biuro Rachunkowe"
  description="Wiadomość wysłana. Odezwiemy się w ciągu 24 godzin."
  noindex={true}
>
  <div style="min-height:80vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:6rem 1.5rem">
    <div>
      <div style="font-size:3rem;margin-bottom:1.5rem">✅</div>
      <h1 style="font-family:var(--font-display);font-size:clamp(1.8rem,4vw,3rem);color:var(--white);margin-bottom:1rem">
        Dziękujemy za wiadomość!
      </h1>
      <p style="color:rgba(255,255,255,0.55);max-width:480px;margin:0 auto 2.5rem;line-height:1.8">
        Odezwiemy się w ciągu <strong style="color:var(--gold)">24 godzin roboczych</strong>.
        W pilnych sprawach zadzwoń bezpośrednio.
      </p>
      <a href="/" class="btn btn-primary">← Wróć na stronę główną</a>
    </div>
  </div>
</BaseLayout>
