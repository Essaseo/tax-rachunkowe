---
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'TAX Biuro Rachunkowe | Profesjonalna obsługa księgowa',
  description = 'TAX Biuro Rachunkowe – kompleksowa obsługa księgowa, kadry i płace, doradztwo podatkowe dla firm i przedsiębiorców. Sprawdź ofertę.',
  canonical = Astro.url.href,
  ogImage = '/images/og-default.jpg',
  noindex = false,
} = Astro.props;

const siteName = 'TAX Biuro Rachunkowe';
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  {!noindex && <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="pl_PL" />
  <meta property="og:site_name" content={siteName} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Theme -->
  <meta name="theme-color" content="#06060f" />

  <!-- Perf: preconnect Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Schema.org: Local Business -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AccountingService",
    "name": "TAX Biuro Rachunkowe",
    "url": "https://tax-bydgoszcz.pl",
    "logo": "https://tax-bydgoszcz.pl/images/logo.png",
    "description": "Profesjonalne biuro rachunkowe – księgowość, kadry, doradztwo podatkowe",
    "telephone": "+48723522852",
    "email": "biuro@tax-bydgoszcz.pl",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Ludwikowo 7/206",
      "addressLocality": "Bydgoszcz",
      "postalCode": "85-502",
      "addressCountry": "PL"
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "17:00"
      }
    ],
    "sameAs": []
  })} />

  <slot name="head" />
</head>
<body>

  <!-- HEADER -->
  <header id="header">
    <div class="container">
      <nav class="nav-inner" aria-label="Nawigacja główna">
        <a href="/" class="nav-logo" aria-label="TAX Biuro Rachunkowe – strona główna">
          <img src="/images/logo.png" alt="TAX Biuro Rachunkowe logo" width="160" height="48" loading="eager" />
        </a>
        <ul class="nav-links" role="list">
          <li><a href="/#uslugi">Usługi</a></li>
          <li><a href="/#dlaczego">O nas</a></li>
          <li><a href="/#cennik">Cennik</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/#kontakt">Kontakt</a></li>
        </ul>
        <div class="nav-cta">
          <a href="tel:+48723522852" class="btn btn-outline" aria-label="Zadzwoń do nas">📞 723 522 852</a>
          <a href="/#kontakt" class="btn btn-primary">Bezpłatna wycena</a>
        </div>
        <button class="hamburger" id="menuBtn" aria-label="Otwórz menu" aria-expanded="false" aria-controls="mobileNav">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </nav>
    </div>
  </header>

  <!-- MOBILE NAV -->
  <nav id="mobileNav" class="mobile-nav" aria-label="Menu mobilne" aria-hidden="true">
    <button class="mobile-close" id="closeBtn" aria-label="Zamknij menu">✕</button>
    <a href="/#uslugi">Usługi</a>
    <a href="/#dlaczego">O nas</a>
    <a href="/#cennik">Cennik</a>
    <a href="/blog">Blog</a>
    <a href="/#kontakt">Kontakt</a>
    <a href="/#kontakt" class="btn btn-primary" style="margin-top:1rem">Bezpłatna wycena</a>
  </nav>

  <main id="main-content">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <img src="/images/logo.png" alt="TAX Biuro Rachunkowe" width="130" height="40" loading="lazy" />
          <p>Profesjonalne biuro rachunkowe. Zajmujemy się Twoją księgowością, abyś mógł skupić się na prowadzeniu firmy.</p>
        </div>
        <div>
          <h4>Usługi</h4>
          <ul class="footer-links">
            <li><a href="/#uslugi">Pełna księgowość</a></li>
            <li><a href="/#uslugi">Uproszczona KPiR</a></li>
            <li><a href="/#uslugi">Kadry i płace</a></li>
            <li><a href="/#uslugi">VAT i JPK</a></li>
            <li><a href="/#uslugi">Doradztwo podatkowe</a></li>
          </ul>
        </div>
        <div>
          <h4>Firma</h4>
          <ul class="footer-links">
            <li><a href="/#dlaczego">O nas</a></li>
            <li><a href="/blog">Blog podatkowy</a></li>
            <li><a href="/#kontakt">Kontakt</a></li>
            <li><a href="/polityka-prywatnosci">Polityka prywatności</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} Biuro Rachunkowe TAX Sp. z o.o. Wszelkie prawa zastrzeżone.</p>
        <p style="color:rgba(255,255,255,0.2);font-size:0.72rem">NIP: 967-145-10-13 | KRS: 0000932902</p>
      </div>
    </div>
  </footer>

  <script>
    // ── Sticky header
    const header = document.getElementById('header');
    window.addEventListener('scroll', () => {
      header?.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // ── Mobile menu
    const menuBtn = document.getElementById('menuBtn');
    const closeBtn = document.getElementById('closeBtn');
    const mobileNav = document.getElementById('mobileNav');

    menuBtn?.addEventListener('click', () => {
      mobileNav?.classList.add('open');
      menuBtn.setAttribute('aria-expanded', 'true');
      mobileNav?.removeAttribute('aria-hidden');
      document.body.style.overflow = 'hidden';
    });

    const closeMenu = () => {
      mobileNav?.classList.remove('open');
      menuBtn?.setAttribute('aria-expanded', 'false');
      mobileNav?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    closeBtn?.addEventListener('click', closeMenu);
    mobileNav?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
  </script>
</body>
</html>
